generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cliente {
  id          String       @id @default(cuid())
  dni         String       @unique
  nombre      String
  telefono    String
  expedientes Expediente[]
  createdAt   DateTime     @default(now())
}

model Expediente {
  id             String           @id @default(cuid())
  numero         String           @unique
  caratula       String
  estado         String
  estadoDetalle  String?
  pendientes     String?
  proxMovimiento String?
  fuero          String?
  juzgado        String?
  clienteId      String
  cliente        Cliente          @relation(fields: [clienteId], references: [id])
  reminders      Reminder[]
  etapa          ExpedienteEtapa?
  updatedAt      DateTime         @updatedAt
}

// ── Etapas predefinidas ──────────────────────────────────────────────────────

model Etapa {
  id          String            @id @default(cuid())
  nombre      String
  descripcion String?
  mensajeBot  String            @db.Text
  proximoPaso String
  esperando   String
  orden       Int               @default(0)
  activa      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  expedientes ExpedienteEtapa[]
}

model ExpedienteEtapa {
  id                String     @id @default(cuid())
  expedienteId      String     @unique
  expediente        Expediente @relation(fields: [expedienteId], references: [id])
  etapaId           String?
  etapa             Etapa?     @relation(fields: [etapaId], references: [id])
  mensajeBotCustom  String?    @db.Text
  proximoPasoCustom String?
  esperandoCustom   String?
  updatedAt         DateTime   @updatedAt
}

// ── Reminders ────────────────────────────────────────────────────────────────

model Reminder {
  id           String           @id @default(cuid())
  expedienteId String
  expediente   Expediente       @relation(fields: [expedienteId], references: [id])
  tipo         String           // AUDIENCIA | VENCIMIENTO | GENERAL
  fechaEvento  DateTime
  intervalos   Int[]            // días de anticipación, e.g. [7, 3, 1]
  mensaje      String?          @db.Text
  lugar        String?
  esVirtual    Boolean          @default(false)
  linkVirtual  String?
  queLlevar    String?
  horaEnvio    String           @default("09:00")
  createdAt    DateTime         @default(now())
  alertas      ReminderAlerta[]
}

model ReminderAlerta {
  id         String    @id @default(cuid())
  reminderId String
  reminder   Reminder  @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  diasAntes  Int
  enviarEn   DateTime
  status     String    @default("pending")
  sentAt     DateTime?
  errorMsg   String?
}

// ── Conversaciones ───────────────────────────────────────────────────────────

model Conversation {
  id          String   @id @default(cuid())
  telefono    String   @unique
  state       String   @default("idle")
  contextData Json?
  lastMsgAt   DateTime @default(now())
  expiresAt   DateTime
}

// ── FAQ en árbol ─────────────────────────────────────────────────────────────

model FaqTema {
  id        String        @id @default(cuid())
  titulo    String
  emoji     String?
  orden     Int           @default(0)
  activo    Boolean       @default(true)
  preguntas FaqPregunta[]
}

model FaqPregunta {
  id        String   @id @default(cuid())
  temaId    String
  tema      FaqTema  @relation(fields: [temaId], references: [id])
  pregunta  String
  respuesta String   @db.Text
  orden     Int      @default(0)
  activa    Boolean  @default(true)
}
